generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Tenancy ───────────────────────────────────────────

model Agent {
  id           String         @id @default(cuid())
  email        String         @unique
  password     String?        // bcrypt hashed. Null for OAuth agents (future)
  name         String
  isApproved   Boolean        @default(false)
  isSuperAdmin Boolean        @default(false)
  maxBranches  Int            @default(1)
  branches     Branch[]
  accounts     Account[]
  sessions     Session[]
  defaults              AgentDefault?
  paymentRecords        PaymentRecord[]
  notifications         Notification[]
  employees             Employee[]
  dispatchers           Dispatcher[]
  companyRegistrationNo    String?
  companyAddress           String?
  avatarUrl                String?    // R2 URL for profile picture
  stampImageUrl            String?    // R2 URL for company stamp on payslips
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model AgentDefault {
  id                 String  @id @default(cuid())
  agentId            String  @unique
  // Weight tiers
  tier1MinWeight     Float   @default(0)
  tier1MaxWeight     Float   @default(5)
  tier1Commission    Float   @default(1.00)
  tier2MinWeight     Float   @default(5.01)
  tier2MaxWeight     Float   @default(10)
  tier2Commission    Float   @default(1.40)
  tier3MinWeight     Float   @default(10.01)
  tier3Commission    Float   @default(2.20)
  // Bonus tiers — apply to parcels above orderThreshold (e.g. #2001+).
  // Weight ranges mirror the weight tiers above; only the commission rates
  // are independently configurable. Defaults are a 50% uplift over weight tiers.
  orderThreshold          Int     @default(2000)
  bonusTier1Commission    Float   @default(1.50)
  bonusTier2Commission    Float   @default(2.10)
  bonusTier3Commission    Float   @default(3.30)
  // Petrol
  petrolEligible     Boolean @default(true)
  dailyThreshold     Int     @default(70)
  subsidyAmount      Float   @default(15)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  agentId           String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  agent             Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([agentId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  agentId      String
  expires      DateTime
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ─────────────────────────────────────────────

model Branch {
  id          String                 @id @default(cuid())
  agentId     String
  code        String                 // raw branch code from J&T data e.g. "PHG379"
  dispatchers Dispatcher[]
  assignments DispatcherAssignment[]
  employees   Employee[]
  uploads     Upload[]
  agent       Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([agentId, code])
  @@index([agentId])
}

model Dispatcher {
  id             String  @id @default(cuid())
  // agentId: direct ownership by agent. Nullable in Phase A to allow the
  // additive migration on existing rows; backfilled to non-null before Phase B
  // flips it to required and drops branchId from this table.
  agentId        String?
  extId          String  // Dispatcher ID from raw data (col M) e.g. "PHG3795023". Moves to DispatcherAssignment in Phase B.
  name           String
  normalizedName String  @default("") // UPPER(TRIM(COLLAPSE_WS(name))) for fallback matching. Backfilled in Phase A.
  icNo           String? // Malaysian MyKad. Was required; now optional — matches data reality.
  gender         Gender  @default(UNKNOWN)
  avatarUrl      String?
  branchId       String  // Moves to DispatcherAssignment in Phase B.
  isPinned       Boolean @default(false)

  agent         Agent?                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  branch        Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignments   DispatcherAssignment[]
  weightTiers   WeightTier[]
  incentiveRule IncentiveRule?
  bonusTiers    BonusTier[]
  petrolRule    PetrolRule?
  salaryRecords SalaryRecord[]
  employees     Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, extId])
  @@index([branchId])
  @@index([extId])
  @@index([agentId])
  @@index([agentId, icNo])
  @@index([agentId, normalizedName])
}

// A dispatcher's assignment to a specific branch. Created in Phase B backfill;
// until then this table is empty and the app continues to read branchId/extId
// directly from Dispatcher.
model DispatcherAssignment {
  id           String    @id @default(cuid())
  dispatcherId String
  branchId     String
  extId        String    // branch-scoped J&T ID
  startedAt    DateTime  @default(now())
  endedAt      DateTime? // null = still assigned

  dispatcher Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, extId])
  @@index([dispatcherId])
  @@index([branchId])
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model WeightTier {
  id           String     @id @default(cuid())
  dispatcherId String
  tier         Int        // 1, 2, or 3
  minWeight    Float
  maxWeight    Float?     // null = no upper bound (tier 3)
  commission   Float      // RM flat rate per parcel in this tier
  dispatcher   Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)

  @@unique([dispatcherId, tier])
  @@index([dispatcherId])
}

model IncentiveRule {
  id             String     @id @default(cuid())
  dispatcherId   String     @unique
  orderThreshold Int        @default(2000)
  dispatcher     Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
}

// Bonus tiers apply to parcels after the dispatcher crosses orderThreshold
// (e.g. parcel #2001 onward). Weight boundaries mirror WeightTier; commissions
// are independently configurable. Typically 3 rows per dispatcher.
model BonusTier {
  id           String     @id @default(cuid())
  dispatcherId String
  tier         Int        // 1, 2, or 3
  minWeight    Float
  maxWeight    Float?     // null = no upper bound (tier 3)
  commission   Float      // RM flat rate per post-threshold parcel in this tier
  dispatcher   Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)

  @@unique([dispatcherId, tier])
  @@index([dispatcherId])
}

model PetrolRule {
  id             String     @id @default(cuid())
  dispatcherId   String     @unique
  isEligible     Boolean    @default(false)
  dailyThreshold Int        @default(70)
  subsidyAmount  Float      @default(15)
  dispatcher     Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
}

// ─── Employees (Supervisor / Admin / Store Keeper) ──────────

enum EmployeeType {
  SUPERVISOR
  ADMIN
  STORE_KEEPER
}

model Employee {
  id          String       @id @default(cuid())
  agentId     String
  extId       String?      // employee ID (optional external identifier)
  name        String
  icNo        String?      // optional until payslip needed
  gender      Gender       @default(UNKNOWN)
  avatarUrl   String?
  type        EmployeeType
  branchId    String?

  // Supervisor/Admin fields
  basicPay        Float?
  petrolAllowance Float    @default(0)
  kpiAllowance    Float    @default(0)
  otherAllowance  Float    @default(0)

  // Statutory reference numbers (for payslips)
  epfNo       String?
  socsoNo     String?
  incomeTaxNo String?

  // Store Keeper fields
  hourlyWage  Float?

  // Dispatcher link
  dispatcherId String?
  dispatcher   Dispatcher? @relation(fields: [dispatcherId], references: [id], onDelete: SetNull)

  branch        Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  agent         Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  salaryRecords EmployeeSalaryRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([branchId])
}

model EmployeeSalaryRecord {
  id         String @id @default(cuid())
  employeeId String
  month      Int
  year       Int

  // Earnings
  basicPay        Float @default(0)
  workingHours    Float @default(0) // store keeper only
  hourlyWage      Float @default(0) // store keeper only
  kpiAllowance    Float @default(0)
  petrolAllowance Float @default(0)
  otherAllowance  Float @default(0)
  grossSalary     Float

  // Statutory (employee share)
  epfEmployee   Float
  socsoEmployee Float
  eisEmployee   Float
  pcb           Float @default(0) // manual

  // Statutory (employer share)
  epfEmployer   Float
  socsoEmployer Float
  eisEmployer   Float

  // Deductions
  penalty Float @default(0)
  advance Float @default(0) // combined dispatcher+employee case only

  netSalary Float

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([month, year])
}

// ─── Uploads & Results ───────────────────────────────────────

enum UploadStatus {
  UPLOADING
  PROCESSING
  CONFIRM_SETTINGS
  NEEDS_ATTENTION
  READY_TO_CONFIRM
  FAILED
  SAVED
}

model Upload {
  id            String         @id @default(cuid())
  branchId      String
  fileName      String
  r2Key         String
  month         Int            // 1–12
  year          Int
  status        UploadStatus   @default(UPLOADING)
  errorMessage  String?
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  salaryRecords SalaryRecord[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([branchId, month, year])
  @@index([branchId])
  @@index([month, year])
  @@index([status])
}

model SalaryRecord {
  id           String @id @default(cuid())
  dispatcherId String
  uploadId     String
  month        Int
  year         Int

  totalOrders       Int
  baseSalary        Float
  bonusTierEarnings Float @default(0)  // total commission from parcels priced at BonusTier rate (post-threshold)
  petrolSubsidy     Float @default(0)
  commission        Float @default(0)  // manual additive commission entered by user, rolls into netSalary
  penalty           Float @default(0)
  advance           Float @default(0)
  netSalary         Float
  petrolQualifyingDays Int @default(0)

  // Snapshots of rules used for this salary calculation (JSON)
  weightTiersSnapshot Json?  // Array<{ tier, minWeight, maxWeight, commission }>
  bonusTierSnapshot   Json?  // New shape: { orderThreshold, tiers: [{tier,minWeight,maxWeight,commission}] }. Legacy shape (pre-bonus-tiers): { orderThreshold, incentiveAmount }. Use readBonusTierSnapshot to discriminate.
  petrolSnapshot      Json?  // { isEligible, dailyThreshold, subsidyAmount }

  lineItems  SalaryLineItem[]
  dispatcher Dispatcher       @relation(fields: [dispatcherId], references: [id])
  upload     Upload           @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([dispatcherId, uploadId])
  @@index([dispatcherId])
  @@index([uploadId])
  @@index([month, year])
  @@index([dispatcherId, month, year])
}

model SalaryLineItem {
  id             String       @id @default(cuid())
  salaryRecordId String
  waybillNumber  String
  weight         Float
  commission     Float
  deliveryDate   DateTime?
  isBonusTier    Boolean      @default(false) // true when this parcel was priced at the dispatcher's BonusTier (i.e. the parcel fell after orderThreshold)
  salaryRecord   SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)

  @@index([salaryRecordId])
}

// ─── Payment Records (Superadmin) ────────────────────────────

model PaymentRecord {
  id        String   @id @default(cuid())
  agentId   String
  amount    Float
  date      DateTime
  notes     String?
  period    String?  // e.g. "March 2026 – February 2027"
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agentId])
}

// ─── Notifications ───────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  agentId   String
  type      String   // "upload" | "payroll" | "new_dispatcher" | "recalculate"
  message   String
  detail    String
  isRead    Boolean  @default(false)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agentId, isRead])
  @@index([agentId, createdAt])
}
