generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Tenancy ───────────────────────────────────────────

model Agent {
  id           String         @id @default(cuid())
  email        String         @unique
  password     String?        // bcrypt hashed. Null for OAuth agents (future)
  name         String
  isApproved   Boolean        @default(false)
  isSuperAdmin Boolean        @default(false)
  maxBranches  Int            @default(1)
  branches     Branch[]
  accounts     Account[]
  sessions     Session[]
  defaults              AgentDefault?
  paymentRecords        PaymentRecord[]
  notifications         Notification[]
  employees             Employee[]
  companyRegistrationNo    String?
  companyAddress           String?
  avatarUrl                String?    // R2 URL for profile picture
  stampImageUrl            String?    // R2 URL for company stamp on payslips
  googleSheetsAccessToken  String?
  googleSheetsRefreshToken String?
  googleSheetsTokenExpiry  DateTime?
  hasSeenTutorial          Boolean    @default(false)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model AgentDefault {
  id                 String  @id @default(cuid())
  agentId            String  @unique
  // Weight tiers
  tier1MinWeight     Float   @default(0)
  tier1MaxWeight     Float   @default(5)
  tier1Commission    Float   @default(1.00)
  tier2MinWeight     Float   @default(5.01)
  tier2MaxWeight     Float   @default(10)
  tier2Commission    Float   @default(1.40)
  tier3MinWeight     Float   @default(10.01)
  tier3Commission    Float   @default(2.20)
  // Incentive
  orderThreshold     Int     @default(2000)
  incentiveAmount    Float   @default(200)
  // Petrol
  petrolEligible     Boolean @default(true)
  dailyThreshold     Int     @default(70)
  subsidyAmount      Float   @default(15)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  agentId           String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  agent             Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([agentId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  agentId      String
  expires      DateTime
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ─────────────────────────────────────────────

model Branch {
  id          String       @id @default(cuid())
  agentId     String
  code        String       // raw branch code from J&T data e.g. "PHG379"
  dispatchers Dispatcher[]
  employees   Employee[]
  uploads     Upload[]
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([agentId, code])
  @@index([agentId])
}

model Dispatcher {
  id        String  @id @default(cuid())
  extId     String  // Dispatcher ID from raw data (col M) e.g. "PHG3795023"
  name      String
  icNo      String  // Malaysian MyKad — mandatory. Last digit: odd = male, even = female
  gender    Gender  @default(UNKNOWN)
  avatarUrl String?
  branchId  String
  isPinned  Boolean @default(false)

  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  weightTiers   WeightTier[]
  incentiveRule IncentiveRule?
  petrolRule    PetrolRule?
  salaryRecords SalaryRecord[]
  employees     Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, extId])
  @@index([branchId])
  @@index([extId])
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model WeightTier {
  id           String     @id @default(cuid())
  dispatcherId String
  tier         Int        // 1, 2, or 3
  minWeight    Float
  maxWeight    Float?     // null = no upper bound (tier 3)
  commission   Float      // RM flat rate per parcel in this tier
  dispatcher   Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)

  @@unique([dispatcherId, tier])
  @@index([dispatcherId])
}

model IncentiveRule {
  id              String     @id @default(cuid())
  dispatcherId    String     @unique
  orderThreshold  Int        @default(2000)
  incentiveAmount Float
  dispatcher      Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
}

model PetrolRule {
  id             String     @id @default(cuid())
  dispatcherId   String     @unique
  isEligible     Boolean    @default(false)
  dailyThreshold Int        @default(70)
  subsidyAmount  Float      @default(15)
  dispatcher     Dispatcher @relation(fields: [dispatcherId], references: [id], onDelete: Cascade)
}

// ─── Employees (Supervisor / Admin / Store Keeper) ──────────

enum EmployeeType {
  SUPERVISOR
  ADMIN
  STORE_KEEPER
}

model Employee {
  id          String       @id @default(cuid())
  agentId     String
  extId       String?      // employee ID (optional external identifier)
  name        String
  icNo        String?      // optional until payslip needed
  gender      Gender       @default(UNKNOWN)
  avatarUrl   String?
  type        EmployeeType
  branchId    String?

  // Supervisor/Admin fields
  basicPay        Float?
  petrolAllowance Float    @default(0)
  kpiAllowance    Float    @default(0)
  otherAllowance  Float    @default(0)

  // Store Keeper fields
  hourlyWage  Float?

  // Dispatcher link
  dispatcherId String?
  dispatcher   Dispatcher? @relation(fields: [dispatcherId], references: [id], onDelete: SetNull)

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  agent  Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([branchId])
}

// ─── Uploads & Results ───────────────────────────────────────

enum UploadStatus {
  UPLOADING
  PROCESSING
  CONFIRM_SETTINGS
  NEEDS_ATTENTION
  READY_TO_CONFIRM
  FAILED
  SAVED
}

model Upload {
  id            String         @id @default(cuid())
  branchId      String
  fileName      String
  r2Key         String
  month         Int            // 1–12
  year          Int
  status        UploadStatus   @default(UPLOADING)
  errorMessage  String?
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  salaryRecords SalaryRecord[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([branchId, month, year])
  @@index([branchId])
  @@index([month, year])
  @@index([status])
}

model SalaryRecord {
  id           String @id @default(cuid())
  dispatcherId String
  uploadId     String
  month        Int
  year         Int

  totalOrders   Int
  baseSalary    Float
  incentive     Float @default(0)
  petrolSubsidy Float @default(0)
  penalty       Float @default(0)
  advance       Float @default(0)
  netSalary     Float
  petrolQualifyingDays Int @default(0)

  // Snapshots of rules used for this salary calculation (JSON)
  weightTiersSnapshot Json?  // Array<{ tier, minWeight, maxWeight, commission }>
  incentiveSnapshot   Json?  // { orderThreshold, incentiveAmount }
  petrolSnapshot      Json?  // { isEligible, dailyThreshold, subsidyAmount }

  lineItems  SalaryLineItem[]
  dispatcher Dispatcher       @relation(fields: [dispatcherId], references: [id])
  upload     Upload           @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([dispatcherId, uploadId])
  @@index([dispatcherId])
  @@index([uploadId])
  @@index([month, year])
  @@index([dispatcherId, month, year])
}

model SalaryLineItem {
  id             String       @id @default(cuid())
  salaryRecordId String
  waybillNumber  String
  weight         Float
  commission     Float
  deliveryDate   DateTime?
  salaryRecord   SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)

  @@index([salaryRecordId])
}

// ─── Payment Records (Superadmin) ────────────────────────────

model PaymentRecord {
  id        String   @id @default(cuid())
  agentId   String
  amount    Float
  date      DateTime
  notes     String?
  period    String?  // e.g. "March 2026 – February 2027"
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agentId])
}

// ─── Notifications ───────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  agentId   String
  type      String   // "upload" | "payroll" | "new_dispatcher" | "recalculate"
  message   String
  detail    String
  isRead    Boolean  @default(false)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agentId, isRead])
  @@index([agentId, createdAt])
}
